# Supabase — copy to .env and fill in from your Supabase project
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key (server-side only — NEVER ship to the client).
# Used by scripts/seed-review-questions.mjs and scripts/pull-review-to-bank.mjs
# to bypass RLS when bulk-reading/writing the review_questions table.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
